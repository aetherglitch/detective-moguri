{
  "manifest_version": 3,
  "name": "Detective Moguri [BETA]",
  "version": "0.1.0",
  "description": "Ayudante para Cardmarket - detecta precios más bajos y duplicados, ¡kupó!",
  "permissions": ["activeTab", "storage", "sidePanel"],
  "host_permissions": ["https://www.cardmarket.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.cardmarket.com/*"],
      "js": ["content/content.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Detective Moguri"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
